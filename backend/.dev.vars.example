# Copy to `.dev.vars` in this directory for local `wrangler dev`.
# Never commit `.dev.vars` тАФ it is gitignored.

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
